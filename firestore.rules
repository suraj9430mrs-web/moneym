rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tracker data — anyone can read, only signed-in users can write
    match /tracker/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Activity feed — anyone can read, only signed-in users can write
    match /activities/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Online viewers — anyone can read and write (presence tracking)
    match /viewers/{document} {
      allow read, write: if true;
    }
  }
}
